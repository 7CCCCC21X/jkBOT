BOT_TOKEN=你的token
CHAT_ID=你的chat id
DEFAULT_CHAIN=bsc
DEFAULT_THRESHOLD_USD=100000
DEFAULT_THRESHOLD_24H_USD=1000000
# 1h 价格变化 >= ±X% 触发告警, 0 = 关闭
DEFAULT_PRICE_ALERT_PCT=10
# 流动性 1 小时内跌 >= X% 触发告警, 0 = 关闭
DEFAULT_LIQ_DROP_PCT=30
# 买卖比失衡阈值, 1h 内 buys/sells 超过 Nx 或 1/Nx 触发, 0 = 关闭
DEFAULT_IMBALANCE_RATIO=5
TIMEZONE=Asia/Shanghai

# 数据目录: 必须挂载为持久卷, 否则每次部署都会丢失数据
# docker-compose 已经帮你配好命名卷 jkbot_data -> /data
DATA_DIR=/data

# SQLite 数据库路径 (单文件, 含 tokens / 告警冷却 / 历史快照)
# 留空则默认 ${DATA_DIR}/bot.db
SQLITE_PATH=/data/bot.db

# 历史快照保留天数 (每小时每代币 1 条)
HISTORY_DAYS=30
